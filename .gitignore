# ========================
# Surge 专属忽略规则
# ========================

# Surge 自动生成的 iOS 界面状态记录（必须忽略，否则每次打开手机 App 都会产生变更）
*.iosinterface

# Surge 动态配置缓存文件（运行时生成的临时状态）
*.dconf

# Surge 自动生成的备份文件
*.bak
*.backup

# 日志文件
*.log

# ========================
# macOS 系统及其他杂项
# ========================

# macOS 文件夹属性记录
.DS_Store
._*
.AppleDouble
.LSOverride

# (可选) 如果你不想同步证书私钥，可以取消下面这行的注释
# *.p12