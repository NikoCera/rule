# NAME: Game
# AUTHOR: myself
# UPDATED: 2026-06-26
# DESCRIPTION: Windows gateway gaming/P2P helper rules for Surge.

# ═══════════════════════ 游戏设备 ═══════════════════════
# WorldMachine / Windows PC (Ethernet / WiFi): 192.168.0.100, 192.168.0.105
# 不单独写 SRC-IP, 避免整台 Windows 的所有 TCP/HTTPS 流量都被直连。

# ═══════════════════════ Tailscale UDP 打洞 ═══════════════════════
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,41641)) // Tailscale/WireGuard 打洞
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,41641)) // Tailscale/WireGuard 打洞

# ═══════════════════════ STUN / TURN / WebRTC / P2P 探测 ═══════════════════════
# DOMAIN-KEYWORD,turn
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,3478-3481)) // STUN/TURN
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,5349)) // STUN/TURN over TLS
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,19302-19309)) // Google STUN (WebRTC)
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,3478-3481)) // STUN/TURN
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,5349)) // STUN/TURN over TLS
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,19302-19309)) // Google STUN (WebRTC)

# ═══════════════════════ Xbox / Windows 游戏常见 UDP ═══════════════════════
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,88)) // Xbox Live / Kerberos
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,500)) // IKE / Teredo
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,3074)) // Xbox Live 主端口
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,3544)) // Teredo (IPv6 NAT 穿透)
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,4500)) // IPSec NAT-T
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,88)) // Xbox Live / Kerberos
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,500)) // IKE / Teredo
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,3074)) // Xbox Live 主端口
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,3544)) // Teredo (IPv6 NAT 穿透)
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,4500)) // IPSec NAT-T

# ═══════════════════════ Steam / PC 联机常见 UDP ═══════════════════════
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,4380)) // Steam
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,27000-27100)) // Steam 游戏/语音
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,4380)) // Steam
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,27000-27100)) // Steam 游戏/语音

# ═══════════════════════ 临时全 UDP 直连开关 ═══════════════════════
# 遇到 NAT 类型严格、匹配失败、房间无法发现或 P2P 连接不稳时，可以临时取消下一行注释。
# AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP))
# AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP))
