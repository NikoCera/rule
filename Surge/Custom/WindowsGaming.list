# NAME: WindowsGaming
# AUTHOR: myself
# UPDATED: 2026-06-24
# DESCRIPTION: Windows gateway gaming/P2P helper rules for Surge.

# ═══════════════════════ Windows 网关设备 ═══════════════════════
# WorldMachine / Windows PC (Ethernet / WiFi): 192.168.0.100, 192.168.0.105
# 不单独写 SRC-IP, 避免整台 Windows 的所有 TCP/HTTPS 流量都被直连。

# ═══════════════════════ Tailscale UDP 打洞 ═══════════════════════
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,41641))
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,41641))

# ═══════════════════════ STUN / TURN / WebRTC / P2P 探测 ═══════════════════════
# DOMAIN-KEYWORD,turn
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,3478-3481))
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,5349))
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,19302-19309))
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,3478-3481))
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,5349))
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,19302-19309))

# ═══════════════════════ Xbox / Windows 游戏常见 UDP ═══════════════════════
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,88))
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,500))
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,3074))
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,3544))
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,4500))
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,88))
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,500))
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,3074))
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,3544))
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,4500))

# ═══════════════════════ Steam / PC 联机常见 UDP ═══════════════════════
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,4380))
AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP),(DEST-PORT,27000-27100))
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,4380))
AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP),(DEST-PORT,27000-27100))

# ═══════════════════════ 临时全 UDP 直连开关 ═══════════════════════
# 遇到 NAT 类型严格、匹配失败、房间无法发现或 P2P 连接不稳时，可以临时取消下一行注释。
# AND,((SRC-IP,192.168.0.100),(PROTOCOL,UDP))
# AND,((SRC-IP,192.168.0.105),(PROTOCOL,UDP))
